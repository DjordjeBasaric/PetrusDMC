# Resend API (https://resend.com) — required for the contact form to send email.
# Create an API key and verify your sending domain (or use onboarding@resend.dev for tests).
RESEND_API_KEY=

# Inbox for contact form submissions (defaults to info@petrustravel.com if unset).
CONTACT_TO_EMAIL=info@petrustravel.com

# Verified sender in Resend, e.g. "Petrus Travel <mail@yourdomain.com>"
CONTACT_FROM_EMAIL=Petrus Travel <onboarding@resend.dev>
